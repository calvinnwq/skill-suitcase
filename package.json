{
  "name": "skill-suitcase",
  "version": "0.12.0",
  "description": "Skill install planner and transactional installer for portable agent skill catalogs.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calvinnwq/skill-suitcase.git"
  },
  "homepage": "https://github.com/calvinnwq/skill-suitcase#readme",
  "bugs": {
    "url": "https://github.com/calvinnwq/skill-suitcase/issues"
  },
  "bin": {
    "skill-suitcase": "dist/src/cli.js"
  },
  "files": [
    "dist/src/**/*.js",
    "skills/skill-suitcase",
    "VISION.md",
    "README.md",
    "INSTALL.md",
    "CHANGELOG.md",
    "docs/*.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/src/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "rm -rf dist && pnpm run build && node --test dist/tests/*.test.js",
    "format:check": "git diff --check",
    "architecture:check": "node scripts/check-architecture.mjs"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
