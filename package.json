{
  "name": "skill-suitcase",
  "version": "0.1.0",
  "private": true,
  "description": "Read-only skill install planner for portable agent skill catalogs.",
  "type": "module",
  "bin": {
    "suitcase": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "rm -rf dist && pnpm run build && node --test dist/tests/*.test.js",
    "format:check": "git diff --check"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
